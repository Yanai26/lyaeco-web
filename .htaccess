# ─── Redirection www → sans www (301 permanent) ──────────────────────────────
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.lyaeco\.com [NC]
RewriteRule ^(.*)$ https://lyaeco.com/$1 [L,R=301]

ErrorDocument 404 /404.html

# ─── Blocage des fichiers sensibles ──────────────────────────────────────────
<FilesMatch "^\.env|^\.env\.|\.log$|tarifs\.json$">
    Order deny,allow
    Deny from all
</FilesMatch>
